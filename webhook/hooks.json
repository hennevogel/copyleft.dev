[
  {
    "id": "make-it-so-master",
    "execute-command": "make",
    "trigger-rule": {
      "and": [
        {
          "match":
          {
            "type": "payload-hmac-sha1",
            "secret": "",
            "parameter":
            {
              "source": "header",
              "name": "X-Hub-Signature"
            }
          }
        },
        {
          "match":
          {
            "type": "value",
            "value": "refs/heads/master",
            "parameter":
            {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  }
]
